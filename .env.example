# Universal Polling needs the shared suite Supabase project for poll storage and
# host email verification (Supabase Auth email OTP). Copy to .env.local and fill
# in the anon (publishable) key — never the service_role key.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
